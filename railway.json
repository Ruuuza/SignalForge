{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile",
    "watchPatterns": [
      "Dockerfile",
      "Directory.Build.props",
      "global.json",
      "RuzoSolutions.sln",
      "src/**"
    ]
  },
  "deploy": {
    "healthcheckPath": "/health",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ALWAYS",
    "drainingSeconds": "30"
  }
}
